# Plex Media Server URL — must be reachable from inside the container.
# Use the host's LAN IP (not localhost, which resolves to the container itself).
# Example: http://192.168.1.100:32400
# On Docker Desktop for Mac/Windows you can also use: http://host.docker.internal:32400
PLEX_SERVER=http://192.168.1.x:32400

# Secret for signing session cookies. Generate one: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-long-random-string

PORT=6767

# OPTIONAL — the admin token is normally obtained by signing in with Plex from the app's
# settings gear (persisted to the config volume). Set this only for a startup fallback.
# PLEX_TOKEN=your-plex-token

# OPTIONAL — leave unset to let each Plex managed user's own library access decide what
# they see. Set it only to further restrict (comma-separated, must match Plex exactly).
# ALLOWED_LIBRARIES=Family Movies,Kids Shows

# OPTIONAL — where the persisted token/PIN/settings live (defaults shown).
# SETTINGS_PATH=/config/settings.json
# AUTH_PATH=/config/auth.json
